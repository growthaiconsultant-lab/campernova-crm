# ============================================================
# Campernova CRM — Plantilla de variables de entorno
# ============================================================
# Este archivo SE COMMITEA al repo (no contiene secretos reales).
# Copia este archivo a `.env.local` y rellena los valores reales.
# `.env.local` está en .gitignore y nunca se sube al repo.
# ============================================================


# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="CampersNova"
NEXT_PUBLIC_APP_URL="https://campersnova.com"
NEXT_PUBLIC_CONTACT_EMAIL="info@campersnova.com"


# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SECRET_KEY="sb_secret_..."

NEXT_PUBLIC_SUPABASE_ANON_KEY="${NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY}"
SUPABASE_SERVICE_ROLE_KEY="${SUPABASE_SECRET_KEY}"

DATABASE_URL="postgresql://postgres.YOUR-PROJECT-REF:YOUR-PASSWORD@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR-PROJECT-REF:YOUR-PASSWORD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"


# ─── Resend ─────────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="info@campersnova.com"
RESEND_FROM_EMAIL_SANDBOX="onboarding@resend.dev"


# ─── Sentry ─────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN="https://...@o....ingest.de.sentry.io/..."
SENTRY_ORG="ai-marketing-solutions"
SENTRY_PROJECT="campernova-crm"
SENTRY_AUTH_TOKEN=""


# ─── PostHog ────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY="phc_..."
NEXT_PUBLIC_POSTHOG_HOST="https://eu.posthog.com"


# ─── hCaptcha ───────────────────────────────────────────────
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=""
HCAPTCHA_SECRET_KEY=""


# ─── GitHub ─────────────────────────────────────────────────
GITHUB_REPO_URL="https://github.com/growthaiconsultant-lab/campernova-crm"


# ─── Linear ─────────────────────────────────────────────────
LINEAR_WORKSPACE_URL="https://linear.app/campersnova"
LINEAR_PROJECT_ID=""
