{
  "name": "campernova-crm",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && tsx scripts/check-remote-migrations.ts && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "check:rls": "tsx scripts/check-rls.ts",
    "check:migration-history": "tsx scripts/check-migration-history.ts",
    "check:remote-migrations": "tsx scripts/check-remote-migrations.ts",
    "check:delivery-offer-nulls": "tsx scripts/check-delivery-offer-nulls.ts",
    "test:integration:prepare": "tsx scripts/integration-prepare.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:ci": "pnpm test:integration:prepare && pnpm check:rls && pnpm test:integration",
    "assert:local-supabase": "tsx scripts/assert-local-supabase.ts",
    "test:supabase": "vitest run --config vitest.supabase.config.ts",
    "documents:audit": "tsx scripts/audit-legacy-documents.ts",
    "documents:audit-storage": "tsx scripts/audit-document-storage.ts",
    "documents:plan-backfill": "tsx scripts/plan-document-backfill.ts",
    "documents:apply-backfill": "tsx scripts/apply-document-backfill.ts",
    "documents:verify-backfill": "tsx scripts/verify-document-backfill.ts",
    "documents:rollback-backfill": "tsx scripts/rollback-document-backfill.ts",
    "documents:plan-storage-reconciliation": "tsx scripts/plan-storage-reconciliation.ts",
    "prepare": "husky",
    "seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.74",
    "@ai-sdk/react": "^3.0.176",
    "@anthropic-ai/sdk": "^0.92.0",
    "@hcaptcha/react-hcaptcha": "^2.0.2",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.51.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "ai": "^6.0.174",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.511.0",
    "next": "14.2.35",
    "posthog-js": "^1.372.6",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.74.0",
    "recharts": "^3.8.1",
    "resend": "^6.12.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@playwright/test": "^1.59.1",
    "@types/jszip": "^3.4.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "postcss": "^8",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "@sentry/cli"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
