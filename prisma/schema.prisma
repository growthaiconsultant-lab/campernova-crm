enum DeliveryChecklistCategory {
  PRE_ENTREGA
  EXPLICACION
  FIRMA_SALIDA
}

enum DeliveryChecklistResult {
  PENDIENTE
  OK
  INCIDENCIA
  NO_APLICA
}

enum DeliveryDocumentCategory {
  CONTRATO_FINAL
  FACTURA
  DOCUMENTO_ENTREGA
  FOTO_ENTREGA
  OTRO
}

enum TicketStatus {
  ABIERTO
  EN_PROGRESO
  RESUELTO
  CERRADO
  ANULADO
}

enum TicketPriority {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

enum TicketPhotoType {
  PROBLEMA
  SOLUCION
}

enum FollowupType {
  DIA_7
  DIA_30
}

enum FollowupStatus {
  PENDIENTE
  ENVIADO
  RESPONDIDO
