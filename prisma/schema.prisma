}

// ─────────────────────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────────────────────

/// Usuarios internos del CRM (agentes y admin).
/// authId referencia auth.users.id de Supabase y se rellena al primer login.
model User {
  id               String    @id @default(cuid())
  authId           String?   @unique @map("auth_id")
  email            String    @unique
  name             String
  role             UserRole  @default(AGENTE)
  active           Boolean   @default(true)
  notifyOnNewLead  Boolean   @default(true) @map("notify_on_new_lead")
  lastMatchEmailAt DateTime? @map("last_match_email_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  sellerLeads              SellerLead[]           @relation("AgentSellerLeads")
  buyerLeads               BuyerLead[]            @relation("AgentBuyerLeads")
  archivedSellerLeads      SellerLead[]           @relation("ArchivedSellerLeads")
  archivedBuyerLeads       BuyerLead[]            @relation("ArchivedBuyerLeads")
  activities               Activity[]
  valuations               Valuation[]
  vehicleAds               VehicleAd[]
  assignedWorkOrders       WorkOrder[]            @relation("AssignedWorkOrders")
  approvedWorkOrders       WorkOrder[]            @relation("ApprovedWorkOrders")
  workOrderTimeEntries     WorkOrderTimeEntry[]
  vehicleCostsCreated      VehicleCost[]
  deliveriesResponsable    Delivery[]             @relation("ResponsableDeliveries")
  warrantiesExtended       Warranty[]
  deliveryDocsUploaded     DeliveryDocument[]
  postventaTicketsResp     PostventaTicket[]      @relation("ResponsibleTickets")
  postventaPhotosUploaded  PostventaTicketPhoto[]
  chargeChecksPerformed    Vehicle[]              @relation("ChargeChecks")
  trustVerifications       Vehicle[]              @relation("TrustVerifications")
  vehicleDocumentsUploaded VehicleDocument[]
  createdCalendarEvents    CalendarEvent[]        @relation("CreatedCalendarEvents")
  assignedCalendarEvents   CalendarEvent[]        @relation("AssignedCalendarEvents")
  createdCaptures          VehicleCapture[]       @relation("CreatedCaptures")
  assignedCaptures         VehicleCapture[]       @relation("AssignedCaptures")
  createdOffers            Offer[]                @relation("CreatedOffers")
  kpiEvents                KpiEvent[]             @relation("KpiEventActor")
  documentVersionsUploaded DocumentVersion[]

  @@map("users")
}

/// Bloque F0 KPIs — evento atómico auditable de negocio. Fuente de verdad para
/// los KPIs de flujo (leads nuevos, conversión, ventas). Se emite desde las
/// server actions en cada transición relevante. `eventName` es String (no enum)
/// para añadir eventos sin migración; los nombres válidos viven en `lib/kpi/events.ts`.
model KpiEvent {
  id                String   @id @default(cuid())
  eventName         String   @map("event_name")
  entityType        String   @map("entity_type")
  entityId          String   @map("entity_id")
  relatedEntityType String?  @map("related_entity_type")
  relatedEntityId   String?  @map("related_entity_id")
  actorUserId       String?  @map("actor_user_id")
  source            String? // 'ui' | 'system' | 'chat' | 'cron'
  metadata          Json     @default("{}")
  occurredAt        DateTime @default(now()) @map("occurred_at")
  createdAt         DateTime @default(now()) @map("created_at")

  actor User? @relation("KpiEventActor", fields: [actorUserId], references: [id])

  @@index([eventName, occurredAt])
  @@index([entityType, entityId])
  @@index([occurredAt])
  @@map("kpi_events")
}

/// Lead de vendedor — persona que quiere vender su vehículo.
model SellerLead {
  id              String           @id @default(cuid())
  name            String
  email           String
  phone           String
  canal           LeadCanal        @default(PRO)
  status          SellerLeadStatus @default(NUEVO)
  source          String?
  agentId         String?          @map("agent_id")
  nextActionType  NextActionType?  @map("next_action_type")
  nextActionDueAt DateTime?        @map("next_action_due_at")
  lostReason      LostReason?      @map("lost_reason")
  lostReasonNotes String?          @map("lost_reason_notes")
  // ── Condiciones de la operación (Seller Supply Graph, Block 17) — nullable / additivo ──
  minPrice        Decimal?         @map("min_price") @db.Decimal(10, 2) // precio mínimo aceptado
  dealType        SellerDealType?  @map("deal_type") // modalidad de acuerdo
  urgency         SellerUrgency?   @map("urgency") // urgencia real por cerrar
  riskLevel       SellerRisk?      @map("risk_level") // riesgo mecánico/documental
  riskNotes       String?          @map("risk_notes") // detalle del riesgo
  gdprConsentAt   DateTime?        @map("gdpr_consent_at")
  gdprConsentIp   String?          @map("gdpr_consent_ip")
  // ── Archivado real (PR B1) — ORTOGONAL al estado comercial, aditivo y reversible ──
  // `archivedAt == null` ⇔ no archivado. NO es soft-delete: el registro sigue existiendo y
  // se sigue encontrando en búsqueda. El backend que lo escribe llega en PR B2.
  archivedAt      DateTime?        @map("archived_at")
  archivedById    String?          @map("archived_by_id")
  archiveReason   ArchiveReason?   @map("archive_reason")
  archiveNotes    String?          @map("archive_notes")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  agent          User?           @relation("AgentSellerLeads", fields: [agentId], references: [id])
  archivedBy     User?           @relation("ArchivedSellerLeads", fields: [archivedById], references: [id], onDelete: SetNull)
  vehicle        Vehicle?
  activities     Activity[]
  documents      Document[]
  tradeInBuyer   BuyerLead?      @relation("BuyerTradeIn")
  calendarEvents CalendarEvent[]
  capture        VehicleCapture?

  @@index([status])
  @@index([agentId])
  @@index([nextActionDueAt])
  @@index([archivedAt])
  @@map("seller_leads")
}

/// Vehículo asociado 1:1 a un SellerLead.
/// equipment es JSONB con flags booleanos: solar, kitchen, bathroom, shower, heating, etc.
model Vehicle {
  id                   String            @id @default(cuid())
  sellerLeadId         String            @unique @map("seller_lead_id")
  brand                String
  model                String
  year                 Int
  km                   Int
  seats                Int // plazas homologadas (de viaje)
  length               Float? // largo en metros
  type                 VehicleType
  // ── Taxonomía RV (Fase #3 v1) — nullable / additivo ──
  category             VehicleCategory?  @map("category")
  bedLayout            BedLayout?        @map("bed_layout")
  sleepingPlaces       Int?              @map("sleeping_places") // plazas para dormir
  bathroomType         BathroomType?     @map("bathroom_type")
  heatingType          HeatingType?      @map("heating_type")
  winterized           Boolean?          @map("winterized") // preparado para invierno
  hasGarage            Boolean?          @map("has_garage") // garaje para bici/moto
  maxMassKg            Int?              @map("max_mass_kg") // MMA → determina carnet B/C1
  heightM              Float?            @map("height_m") // altura en metros
  offGrid              Boolean?          @map("off_grid") // autonomía real (litio + solar)
  equipment            Json              @default("{}")
  conservationState    ConservationState @default(NORMAL) @map("conservation_state")
  location             String?
  desiredPrice         Decimal?          @map("desired_price") @db.Decimal(10, 2)
  valuationMin         Decimal?          @map("valuation_min") @db.Decimal(10, 2)
  valuationRecommended Decimal?          @map("valuation_recommended") @db.Decimal(10, 2)
  valuationMax         Decimal?          @map("valuation_max") @db.Decimal(10, 2)
  publicNotes          String?           @map("public_notes")
  purchasePrice        Decimal?          @map("purchase_price") @db.Decimal(10, 2)
  salePrice            Decimal?          @map("sale_price") @db.Decimal(10, 2)
  marginPercent        Decimal           @default(4.0) @map("margin_percent") @db.Decimal(5, 2)
  entryDate            DateTime?         @map("entry_date")
  naveLocation         String?           @map("nave_location")
  plate                String?           @map("plate")
  vin                  String?           @map("vin")
  itvValidUntil        DateTime?         @map("itv_valid_until")
  titleTransferredAt   DateTime?         @map("title_transferred_at")
  chargeCheckedAt      DateTime?         @map("charge_checked_at")
  chargeCheckedById    String?           @map("charge_checked_by_id")
  // ── Trust Passport (Block 20) — sello "Verificado por CampersNova" ──
  trustVerifiedAt      DateTime?         @map("trust_verified_at")
  trustVerifiedById    String?           @map("trust_verified_by_id")
  trustNotes           String?           @map("trust_notes")
  status               VehicleStatus     @default(NUEVO)
  publishedAt          DateTime?         @map("published_at")
  soldAt               DateTime?         @map("sold_at")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  sellerLead      SellerLead        @relation(fields: [sellerLeadId], references: [id], onDelete: Cascade)
  chargeCheckedBy User?             @relation("ChargeChecks", fields: [chargeCheckedById], references: [id])
  trustVerifiedBy User?             @relation("TrustVerifications", fields: [trustVerifiedById], references: [id])
  photos          VehiclePhoto[]
  valuations      Valuation[]
  matches         Match[]
  ads             VehicleAd[]
  costs           VehicleCost[]
  workOrders      WorkOrder[]
  deliveries      Delivery[]
  warranty        Warranty?
  documents       VehicleDocument[]
  calendarEvents  CalendarEvent[]
  offers          Offer[]

  @@index([brand, model])
  @@index([status])
  @@index([type, status])
  @@index([plate])
  @@index([vin])
  @@map("vehicles")
}

/// Fotos del vehículo almacenadas en Supabase Storage (bucket vehicle-photos).
model VehiclePhoto {
  id        String   @id @default(cuid())
  vehicleId String   @map("vehicle_id")
  url       String
  order     Int
  altText   String?  @map("alt_text")
  createdAt DateTime @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, order])
  @@map("vehicle_photos")
}

/// Histórico de tasaciones (automáticas y manuales) por vehículo.
model Valuation {
  id          String              @id @default(cuid())
  vehicleId   String              @map("vehicle_id")
  min         Decimal             @db.Decimal(10, 2)
  recommended Decimal             @db.Decimal(10, 2)
  max         Decimal             @db.Decimal(10, 2)
  method      ValuationMethod
  confidence  ValuationConfidence
  parameters  Json                @default("{}") // inputs del algoritmo para auditoría
  createdById String?             @map("created_by_id")
  createdAt   DateTime            @default(now()) @map("created_at")

  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdBy User?   @relation(fields: [createdById], references: [id])

  @@index([vehicleId])
  @@map("valuations")
}

/// Lead de comprador — persona que busca comprar un vehículo.
/// criticalEquipment es JSONB con flags: solar, kitchen, bathroom, shower, heating.
model BuyerLead {
  id                     String              @id @default(cuid())
  name                   String
  email                  String
  phone                  String
  agentId                String?             @map("agent_id")
  vehicleType            VehicleType?        @map("vehicle_type")
  minSeats               Int?                @map("min_seats") // plazas de viaje requeridas (homologadas)
  maxBudget              Decimal?            @map("max_budget") @db.Decimal(10, 2)
  // ── Financiación (Buyer Demand Graph, Block 17) — nullable / additivo ──
  financingNeeded        Boolean?            @map("financing_needed") // ¿necesita financiación?
  maxMonthlyPayment      Decimal?            @map("max_monthly_payment") @db.Decimal(10, 2) // cuota máx. mensual
  criticalEquipment      Json                @default("{}") @map("critical_equipment")
  useZone                String?             @map("use_zone")
  purchaseTimeline       String?             @map("purchase_timeline")
  // ── Preferencias RV (Fase #3 v1) — nullable / additivo ──
  preferredCategory      VehicleCategory?    @map("preferred_category") // preferencia (puntúa)
  preferredBedLayout     BedLayout?          @map("preferred_bed_layout") // preferencia (puntúa)
  sleepingPlacesRequired Int?                @map("sleeping_places_required") // excluyente
  bathroomRequired       Boolean?            @map("bathroom_required") // excluyente si true
  licenseType            LicenseType?        @map("license_type") // B → excluye vehículos > 3.500 kg
  needsWinter            Boolean?            @map("needs_winter") // penaliza si no está preparado
  needsGarage            Boolean?            @map("needs_garage") // preferencia
  maxLengthM             Float?              @map("max_length_m") // restricción parking (excluyente si def.)
  maxHeightM             Float?              @map("max_height_m") // restricción parking (excluyente si def.)
  hasKids                Boolean?            @map("has_kids") // → literas / Isofix (preferencia)
  status                 BuyerLeadStatus     @default(NUEVO)
  source                 String?
  nextActionType         NextActionType?     @map("next_action_type")
  nextActionDueAt        DateTime?           @map("next_action_due_at")
  lostReason             LostReason?         @map("lost_reason")
  lostReasonNotes        String?             @map("lost_reason_notes")
  temperature            LeadTemperature?    @map("temperature")
  // ── Vehículo de parte de pago / trade-in (CAM-63) — nullable / additivo ──
  hasTradeIn             Boolean?            @map("has_trade_in")
  tradeInType            TradeInVehicleType? @map("trade_in_type")
  tradeInBrand           String?             @map("trade_in_brand")
  tradeInModel           String?             @map("trade_in_model")
  tradeInYear            Int?                @map("trade_in_year")
  tradeInKm              Int?                @map("trade_in_km")
  tradeInFinancePending  Boolean?            @map("trade_in_finance_pending")
  tradeInNotes           String?             @map("trade_in_notes")
  tradeInSellerLeadId    String?             @unique @map("trade_in_seller_lead_id")
  // ── Archivado real (PR B1) — ORTOGONAL al estado comercial, aditivo y reversible ──
  // `archivedAt == null` ⇔ no archivado. NO es soft-delete: el registro sigue existiendo y
  // se sigue encontrando en búsqueda. El backend que lo escribe llega en PR B2.
  archivedAt             DateTime?           @map("archived_at")
  archivedById           String?             @map("archived_by_id")
  archiveReason          ArchiveReason?      @map("archive_reason")
  archiveNotes           String?             @map("archive_notes")
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")

  agent             User?             @relation("AgentBuyerLeads", fields: [agentId], references: [id])
  archivedBy        User?             @relation("ArchivedBuyerLeads", fields: [archivedById], references: [id], onDelete: SetNull)
  matches           Match[]
  activities        Activity[]
  documents         Document[]
  chatSession       BuyerChatSession?
  deliveries        Delivery[]
  warranty          Warranty?
  tradeInSellerLead SellerLead?       @relation("BuyerTradeIn", fields: [tradeInSellerLeadId], references: [id])
  calendarEvents    CalendarEvent[]
  offers            Offer[]

  @@index([status])
  @@index([agentId])
  @@index([nextActionDueAt])
  @@index([archivedAt])
  @@map("buyer_leads")
}

/// Sesión de chat para captación de comprador vía /comprar.
model BuyerChatSession {
  id           String          @id @default(cuid())
  sessionToken String          @unique @map("session_token")
  status       BuyerChatStatus @default(IN_PROGRESS)

  messages Json @default("[]")

  capturedNombre         String? @map("captured_nombre")
  capturedEmail          String? @map("captured_email")
  capturedTelefono       String? @map("captured_telefono")
  capturedNecesidad      String? @map("captured_necesidad")
  capturedPlazas         Int?    @map("captured_plazas")
  capturedPresupuestoMin Int?    @map("captured_presupuesto_min")
  capturedPresupuestoMax Int?    @map("captured_presupuesto_max")
  capturedPlazos         String? @map("captured_plazos")
  capturedEquipamiento   Json?   @map("captured_equipamiento")
  capturedZona           String? @map("captured_zona")

  gdprConsentAt DateTime? @map("gdpr_consent_at")
  gdprConsentIp String?   @map("gdpr_consent_ip")

  buyerLeadId String?    @unique @map("buyer_lead_id")
  buyerLead   BuyerLead? @relation(fields: [buyerLeadId], references: [id])

  ipAddress      String? @map("ip_address")
  userAgent      String? @map("user_agent")
  llmModel       String  @default("claude-haiku-4-5-20251001") @map("llm_model")
  totalTokens    Int     @default(0) @map("total_tokens")
  totalCostCents Int     @default(0) @map("total_cost_cents")

  startedAt     DateTime  @default(now()) @map("started_at")
  lastMessageAt DateTime  @default(now()) @map("last_message_at")
  completedAt   DateTime? @map("completed_at")

  @@index([status])
  @@index([startedAt])
  @@map("buyer_chat_sessions")
}

/// Sugerencia de match entre un vehículo y un comprador.
/// score 0-100. Constraint único evita duplicados.
model Match {
  id          String      @id @default(cuid())
  vehicleId   String      @map("vehicle_id")
  buyerLeadId String      @map("buyer_lead_id")
  score       Int
  generatedBy String      @default("auto") @map("generated_by") // "auto" | "manual"
  status      MatchStatus @default(SUGERIDO)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  vehicle        Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  buyerLead      BuyerLead       @relation(fields: [buyerLeadId], references: [id], onDelete: Cascade)
  calendarEvents CalendarEvent[]
  offers         Offer[]

  @@unique([vehicleId, buyerLeadId])
  @@index([buyerLeadId])
  @@map("matches")
}

/// Oferta de un comprador por un vehículo (Transaction & Financing Layer, Block 18).
/// Captura el importe negociado y la señal — la base de "precios reales de cierre".
/// Reserva = oferta ACEPTADA con `depositAmount`. La venta final (VENDIDO) sigue
/// viviendo en el flujo de Vehicle/Delivery; aquí no se duplica.
model Offer {
  id              String      @id @default(cuid())
  vehicleId       String      @map("vehicle_id")
  buyerLeadId     String      @map("buyer_lead_id")
  matchId         String?     @map("match_id")
  amount          Decimal     @map("amount") @db.Decimal(10, 2) // importe ofertado / acordado
  depositAmount   Decimal?    @map("deposit_amount") @db.Decimal(10, 2) // señal (si reservado)
  status          OfferStatus @default(PROPUESTA)
  reservedUntil   DateTime?   @map("reserved_until") // reserva válida hasta
  notes           String?
  rejectionReason LostReason? @map("rejection_reason")
  createdById     String      @map("created_by_id")
  decidedAt       DateTime?   @map("decided_at") // cuándo se aceptó/rechazó/cerró
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  buyerLead BuyerLead @relation(fields: [buyerLeadId], references: [id], onDelete: Cascade)
  match     Match?    @relation(fields: [matchId], references: [id], onDelete: SetNull)
  createdBy User      @relation("CreatedOffers", fields: [createdById], references: [id])

  @@index([vehicleId, status])
  @@index([buyerLeadId, status])
  @@index([status])
  @@map("offers")
}

/// Timeline de actividad polimórfico: cada row pertenece a un SellerLead O a un BuyerLead.
model Activity {
  id           String       @id @default(cuid())
  type         ActivityType
  content      String?
  agentId      String?      @map("agent_id")
  sellerLeadId String?      @map("seller_lead_id")
  buyerLeadId  String?      @map("buyer_lead_id")
  createdAt    DateTime     @default(now()) @map("created_at")

  agent      User?       @relation(fields: [agentId], references: [id])
  sellerLead SellerLead? @relation(fields: [sellerLeadId], references: [id], onDelete: Cascade)
  buyerLead  BuyerLead?  @relation(fields: [buyerLeadId], references: [id], onDelete: Cascade)

  @@index([sellerLeadId, createdAt])
  @@index([buyerLeadId, createdAt])
  @@map("activities")
}

/// Documentos adjuntos (DNI, ITV, contrato…) en leads de vendedor o comprador.
model Document {
  id           String       @id @default(cuid())
  type         DocumentType
  url          String
  name         String?
  sellerLeadId String?      @map("seller_lead_id")
  buyerLeadId  String?      @map("buyer_lead_id")
  createdAt    DateTime     @default(now()) @map("created_at")

  sellerLead SellerLead? @relation(fields: [sellerLeadId], references: [id], onDelete: Cascade)
  buyerLead  BuyerLead?  @relation(fields: [buyerLeadId], references: [id], onDelete: Cascade)

  @@map("documents")
}

/// Anuncio generado por IA para un vehículo en un canal de venta.
model VehicleAd {
  id          String    @id @default(cuid())
  vehicleId   String    @map("vehicle_id")
  channel     AdChannel
  content     String    @db.Text
  modelUsed   String    @map("model_used")
  tokensUsed  Int       @default(0) @map("tokens_used")
  createdById String?   @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdBy User?   @relation(fields: [createdById], references: [id])

  @@index([vehicleId, channel, createdAt(sort: Desc)])
  @@map("vehicle_ads")
}

/// Coste individual imputado a un vehículo (manual o auto-generado desde orden de taller).
model VehicleCost {
  id          String              @id @default(cuid())
  vehicleId   String              @map("vehicle_id")
  category    VehicleCostCategory
  description String
  amount      Decimal             @db.Decimal(10, 2)
  supplier    String?
  invoiceUrl  String?             @map("invoice_url")
  createdById String?             @map("created_by_id")
  workOrderId String?             @map("work_order_id")
  createdAt   DateTime            @default(now()) @map("created_at")

  vehicle   Vehicle    @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdBy User?      @relation(fields: [createdById], references: [id])
  workOrder WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)

  @@index([vehicleId, category])
  @@index([workOrderId])
  @@map("vehicle_costs")
}

/// Orden de trabajo de taller asociada a un vehículo.
model WorkOrder {
  id             String                 @id @default(cuid())
  vehicleId      String                 @map("vehicle_id")
  status         WorkOrderStatus        @default(PENDIENTE)
  kind           WorkOrderKind          @default(REPARACION)
  description    String
  assignedToId   String?                @map("assigned_to_id")
  estimatedHours Decimal?               @map("estimated_hours") @db.Decimal(6, 2)
  estimatedCost  Decimal?               @map("estimated_cost") @db.Decimal(10, 2)
  approvalLevel  WorkOrderApprovalLevel @default(NO_REQUIERE) @map("approval_level")
  approvalLimit  Decimal                @default(500.00) @map("approval_limit") @db.Decimal(10, 2)
  approvedById   String?                @map("approved_by_id")
  approvedAt     DateTime?              @map("approved_at")
  startedAt      DateTime?              @map("started_at")
  completedAt    DateTime?              @map("completed_at")
  // Planificación/agenda del taller (capacidad): ventana de trabajo reservada en el calendario.
  // `estimatedHours` actúa como horas PREVISTAS; `timeEntries` son las horas REALES.
  scheduledStart DateTime?              @map("scheduled_start")
  scheduledEnd   DateTime?              @map("scheduled_end")
  notes          String?
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  vehicle     Vehicle              @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  assignedTo  User?                @relation("AssignedWorkOrders", fields: [assignedToId], references: [id])
  approvedBy  User?                @relation("ApprovedWorkOrders", fields: [approvedById], references: [id])
  checklist   WorkOrderChecklist[]
  timeEntries WorkOrderTimeEntry[]
  parts       WorkOrderPart[]
  costs       VehicleCost[]

  @@index([vehicleId])
  @@index([assignedToId, status])
  @@index([status])
  @@index([assignedToId, scheduledStart])
  @@map("work_orders")
}

/// Ítem individual del checklist técnico de una orden de taller.
model WorkOrderChecklist {
  id          String                @id @default(cuid())
  workOrderId String                @map("work_order_id")
  category    ChecklistItemCategory
  item        String
  result      ChecklistItemResult   @default(PENDIENTE)
  notes       String?
  photos      Json                  @default("[]")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId, category])
  @@map("work_order_checklist")
}

/// Registro de horas imputadas por un trabajador a una orden de taller.
model WorkOrderTimeEntry {
  id          String   @id @default(cuid())
  workOrderId String   @map("work_order_id")
  workerId    String   @map("worker_id")
  hours       Decimal  @db.Decimal(5, 2)
  hourlyRate  Decimal  @default(30.00) @map("hourly_rate") @db.Decimal(6, 2)
  description String
  workDate    DateTime @map("work_date")
  createdAt   DateTime @default(now()) @map("created_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  worker    User      @relation(fields: [workerId], references: [id])

  @@index([workOrderId])
  @@index([workerId, workDate])
  @@map("work_order_time_entries")
}

/// Pieza o repuesto usado en una orden de taller.
model WorkOrderPart {
  id          String   @id @default(cuid())
  workOrderId String   @map("work_order_id")
  name        String
  quantity    Int      @default(1)
  unitCost    Decimal  @map("unit_cost") @db.Decimal(10, 2)
  supplier    String?
  invoiceUrl  String?  @map("invoice_url")
  createdAt   DateTime @default(now()) @map("created_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@map("work_order_parts")
}

/// Entrega física del vehículo al comprador. Ligada a un Vehicle + BuyerLead.
model Delivery {
  id                 String         @id @default(cuid())
  vehicleId          String         @map("vehicle_id")
  buyerLeadId        String         @map("buyer_lead_id")
  responsableId      String?        @map("responsable_id")
  scheduledAt        DateTime       @map("scheduled_at")
  startedAt          DateTime?      @map("started_at")
  completedAt        DateTime?      @map("completed_at")
  status             DeliveryStatus @default(PROGRAMADA)
  signedByName       String?        @map("signed_by_name")
  signedByDni        String?        @map("signed_by_dni")
  signatureUrl       String?        @map("signature_url")
  notes              String?
  cancellationReason String?        @map("cancellation_reason")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  vehicle     Vehicle                 @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  buyerLead   BuyerLead               @relation(fields: [buyerLeadId], references: [id])
  responsable User?                   @relation("ResponsableDeliveries", fields: [responsableId], references: [id])
  checklist   DeliveryChecklistItem[]
  documents   DeliveryDocument[]
  warranty    Warranty?

  @@index([vehicleId])
  @@index([buyerLeadId])
  @@index([responsableId, status])
  @@index([status, scheduledAt])
  @@map("deliveries")
}

/// Ítem del checklist de pre-entrega y explicación al comprador.
model DeliveryChecklistItem {
  id         String                    @id @default(cuid())
  deliveryId String                    @map("delivery_id")
  category   DeliveryChecklistCategory
  item       String
  result     DeliveryChecklistResult   @default(PENDIENTE)
  notes      String?
  createdAt  DateTime                  @default(now()) @map("created_at")
  updatedAt  DateTime                  @updatedAt @map("updated_at")

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId, category])
  @@map("delivery_checklist_items")
}

/// Documento adjunto generado en la entrega (contratos, facturas, fotos).
model DeliveryDocument {
  id               String                   @id @default(cuid())
  deliveryId       String                   @map("delivery_id")
  category         DeliveryDocumentCategory
  name             String
  url              String
  uploadedById     String?                  @map("uploaded_by_id")
  currentVersionId String?                  @map("current_version_id")
  versionSequence  Int                      @default(0) @map("version_sequence")
  createdAt        DateTime                 @default(now()) @map("created_at")

  delivery       Delivery          @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  uploadedBy     User?             @relation(fields: [uploadedById], references: [id])
  versions       DocumentVersion[] @relation("DeliveryDocumentVersions")
  // FK compuesta: la versión actual DEBE pertenecer a esta misma raíz (deliveryDocumentId = id).
  currentVersion DocumentVersion?  @relation("DeliveryCurrentVersion", fields: [id, currentVersionId], references: [deliveryDocumentId, id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([id, currentVersionId])
  @@index([deliveryId])
  @@map("delivery_documents")
}

/// Estado de una versión física de documento (PR5B1).
enum DocumentVersionStatus {
  ACTIVE
  REPLACED
  DELETED
}

/// Versión física versionada de un documento (PR5B1, Opción C). Pertenece a EXACTAMENTE una
/// raíz lógica (VehicleDocument XOR DeliveryDocument) mediante FKs explícitas. La versión
/// actual la determina el puntero `currentVersionId` de la raíz (no un `isCurrent` redundante),
/// garantizado por una FK compuesta que exige que la actual pertenezca a esa misma raíz. Los
/// invariantes cross-table (una raíz, versión eliminada ≠ actual) los aseguran CHECKs + el
/// servicio transaccional. `checksum` es nullable (no se calcula en PR5B1). El objeto físico
/// histórico se conserva; el reemplazo nunca sobrescribe un objectPath.
model DocumentVersion {
  id                 String                @id @default(cuid())
  vehicleDocumentId  String?               @map("vehicle_document_id")
  deliveryDocumentId String?               @map("delivery_document_id")
  version            Int
  bucket             String
  objectPath         String                @unique @map("object_path")
  originalFilename   String?               @map("original_filename")
  mimeType           String?               @map("mime_type")
  sizeBytes          Int?                  @map("size_bytes")
  checksum           String?
  status             DocumentVersionStatus @default(ACTIVE)
  uploadedById       String?               @map("uploaded_by_id")
  createdAt          DateTime              @default(now()) @map("created_at")
  replacedAt         DateTime?             @map("replaced_at")
  deletedAt          DateTime?             @map("deleted_at")

  vehicleDocument  VehicleDocument?  @relation("VehicleDocumentVersions", fields: [vehicleDocumentId], references: [id], onDelete: Cascade)
  deliveryDocument DeliveryDocument? @relation("DeliveryDocumentVersions", fields: [deliveryDocumentId], references: [id], onDelete: Cascade)
  uploadedBy       User?             @relation(fields: [uploadedById], references: [id])

  currentOfVehicleDocument  VehicleDocument?  @relation("VehicleCurrentVersion")
  currentOfDeliveryDocument DeliveryDocument? @relation("DeliveryCurrentVersion")

  @@unique([vehicleDocumentId, version])
  @@unique([deliveryDocumentId, version])
  @@unique([vehicleDocumentId, id])
  @@unique([deliveryDocumentId, id])
  @@index([vehicleDocumentId])
  @@index([deliveryDocumentId])
  @@map("document_versions")
}

/// Garantía activada automáticamente al completar la entrega (12 meses, ampliable a 36).
model Warranty {
  id           String    @id @default(cuid())
  vehicleId    String    @unique @map("vehicle_id")
  deliveryId   String    @unique @map("delivery_id")
  buyerLeadId  String    @unique @map("buyer_lead_id")
  startDate    DateTime  @map("start_date")
  endDate      DateTime  @map("end_date")
  extendedTo   DateTime? @map("extended_to")
  extendedAt   DateTime? @map("extended_at")
  extendedById String?   @map("extended_by_id")
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  vehicle    Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  delivery   Delivery            @relation(fields: [deliveryId], references: [id])
  buyerLead  BuyerLead           @relation(fields: [buyerLeadId], references: [id])
  extendedBy User?               @relation(fields: [extendedById], references: [id])
  tickets    PostventaTicket[]
  followups  PostventaFollowup[]

  @@index([vehicleId])
  @@index([endDate])
  @@map("warranties")
}

/// Ticket de incidencia de garantía abierto por o para el comprador.
/// Al cerrarse con costReal > 0 genera un VehicleCost category=POSTVENTA.
model PostventaTicket {
  id            String         @id @default(cuid())
  warrantyId    String         @map("warranty_id")
  status        TicketStatus   @default(ABIERTO)
  priority      TicketPriority @default(MEDIA)
  title         String
  description   String
  cause         String?
  solution      String?
  costEstimate  Decimal?       @map("cost_estimate") @db.Decimal(10, 2)
  costReal      Decimal?       @map("cost_real") @db.Decimal(10, 2)
  responsibleId String?        @map("responsible_id")
  openedAt      DateTime       @default(now()) @map("opened_at")
  dueAt         DateTime?      @map("due_at")
  resolvedAt    DateTime?      @map("resolved_at")
  closedAt      DateTime?      @map("closed_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  warranty    Warranty               @relation(fields: [warrantyId], references: [id], onDelete: Cascade)
  responsible User?                  @relation("ResponsibleTickets", fields: [responsibleId], references: [id])
  photos      PostventaTicketPhoto[]

  @@index([warrantyId, status])
  @@index([responsibleId, status])
  @@index([status, priority, dueAt])
  @@map("postventa_tickets")
}

/// Foto adjunta a un ticket de postventa (problema o solución).
model PostventaTicketPhoto {
  id           String          @id @default(cuid())
  ticketId     String          @map("ticket_id")
  type         TicketPhotoType
  url          String
  uploadedById String?         @map("uploaded_by_id")
  createdAt    DateTime        @default(now()) @map("created_at")

  ticket     PostventaTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy User?           @relation(fields: [uploadedById], references: [id])

  @@index([ticketId, type])
  @@map("postventa_ticket_photos")
}

/// Seguimiento automático día 7 y día 30 tras la entrega.
/// El cron diario procesa los PENDIENTE con scheduledFor <= now().
model PostventaFollowup {
  id            String         @id @default(cuid())
  warrantyId    String         @map("warranty_id")
  type          FollowupType
  status        FollowupStatus @default(PENDIENTE)
  scheduledFor  DateTime       @map("scheduled_for")
  sentAt        DateTime?      @map("sent_at")
  respondedAt   DateTime?      @map("responded_at")
  responseNotes String?        @map("response_notes")
  failureReason String?        @map("failure_reason")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  warranty Warranty @relation(fields: [warrantyId], references: [id], onDelete: Cascade)

  @@unique([warrantyId, type])
  @@index([status, scheduledFor])
  @@map("postventa_followups")
}

/// Evento propio del calendario operativo (F2): citas, limpiezas, seguimientos, otros.
/// Se agrega en la vista de calendario junto a Entregas/Taller/Postventa/Próximas acciones.
model CalendarEvent {
  id              String                @id @default(cuid())
  type            CalendarEventType
  title           String
  description     String?
  status          CalendarEventStatus   @default(PROGRAMADO)
  priority        CalendarEventPriority @default(MEDIA)
  startAt         DateTime              @map("start_at")
  endAt           DateTime?             @map("end_at")
  durationMinutes Int?                  @map("duration_minutes")
  allDay          Boolean               @default(false) @map("all_day")
  location        String?

  createdById  String  @map("created_by_id")
  assignedToId String? @map("assigned_to_id")
  buyerLeadId  String? @map("buyer_lead_id")
  sellerLeadId String? @map("seller_lead_id")
  vehicleId    String? @map("vehicle_id")
  matchId      String? @map("match_id")

  resultNotes        String?   @map("result_notes")
  internalNotes      String?   @map("internal_notes")
  specificData       Json?     @map("specific_data")
  completedAt        DateTime? @map("completed_at")
  cancelledAt        DateTime? @map("cancelled_at")
  cancellationReason String?   @map("cancellation_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy  User        @relation("CreatedCalendarEvents", fields: [createdById], references: [id])
  assignedTo User?       @relation("AssignedCalendarEvents", fields: [assignedToId], references: [id])
  buyerLead  BuyerLead?  @relation(fields: [buyerLeadId], references: [id], onDelete: Cascade)
  sellerLead SellerLead? @relation(fields: [sellerLeadId], references: [id], onDelete: Cascade)
  vehicle    Vehicle?    @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  match      Match?      @relation(fields: [matchId], references: [id], onDelete: SetNull)

  @@index([startAt])
  @@index([assignedToId, startAt])
  @@index([buyerLeadId])
  @@index([vehicleId])
  @@index([status])
  @@map("calendar_events")
}

/// Captación de vehículo encontrado por un comercial en un portal externo
/// (Coches.net, Wallapop…). Entidad LIGERA = fase 0 del embudo del vendedor;
/// convierte a SellerLead+Vehicle cuando el vehículo llega a la nave.
model VehicleCapture {
  id                 String        @id @default(cuid())
  listingUrl         String        @map("listing_url")
  phone              String
  portal             CapturePortal @default(OTRO)
  title              String? // etiqueta corta (marca/modelo) opcional
  askingPrice        Decimal?      @map("asking_price") @db.Decimal(10, 2)
  status             CaptureStatus @default(NO_CONTACTADO)
  notes              String?
  rejectionReason    LostReason?   @map("rejection_reason")
  entradaScheduledAt DateTime?     @map("entrada_scheduled_at")
  assignedToId       String?       @map("assigned_to_id")
  createdById        String        @map("created_by_id")
  sellerLeadId       String?       @unique @map("seller_lead_id")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  assignedTo User?       @relation("AssignedCaptures", fields: [assignedToId], references: [id])
  createdBy  User        @relation("CreatedCaptures", fields: [createdById], references: [id])
  sellerLead SellerLead? @relation(fields: [sellerLeadId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([assignedToId, status])
  @@index([entradaScheduledAt])
  @@map("vehicle_captures")
}

/// Documento legal asociado al expediente del vehículo (DNI, contratos, ITV, etc.)
model VehicleDocument {
  id               String                  @id @default(cuid())
  vehicleId        String                  @map("vehicle_id")
  category         VehicleDocumentCategory
  name             String
  url              String
  fileSize         Int?                    @map("file_size")
  mimeType         String?                 @map("mime_type")
  notes            String?
  uploadedById     String?                 @map("uploaded_by_id")
  currentVersionId String?                 @map("current_version_id")
  versionSequence  Int                     @default(0) @map("version_sequence")
  createdAt        DateTime                @default(now()) @map("created_at")

  vehicle        Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  uploadedBy     User?             @relation(fields: [uploadedById], references: [id])
  versions       DocumentVersion[] @relation("VehicleDocumentVersions")
  // FK compuesta: la versión actual DEBE pertenecer a esta misma raíz (vehicleDocumentId = id).
  currentVersion DocumentVersion?  @relation("VehicleCurrentVersion", fields: [id, currentVersionId], references: [vehicleDocumentId, id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([id, currentVersionId])
  @@index([vehicleId, category])
  @@map("vehicle_documents")
}

/// Tabla de precios de referencia para el algoritmo de tasación.
/// Poblada manualmente con datos de Wallapop / coches.net al inicio.
model ReferencePrice {
  id                String      @id @default(cuid())
  brand             String
  model             String
  type              VehicleType
  baseYear          Int         @map("base_year")
  basePrice         Decimal     @map("base_price") @db.Decimal(10, 2)
  depreciationPerKm Decimal     @map("depreciation_per_km") @db.Decimal(10, 6)
  notes             String?
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  @@unique([brand, model, type, baseYear])
  @@index([brand, model, type])
  @@map("reference_prices")
}
