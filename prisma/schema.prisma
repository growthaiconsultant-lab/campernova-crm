generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN // Joel, Esteban — acceso total
  AGENTE // Desirée, comerciales — comercial + lectura general
  TALLER // Manolo — solo módulo taller + ver vehículos
  ENTREGAS // Javi — entregas + postventa
  MARKETING // Ari — anuncios + fotos + lectura vehículos
}

enum LeadCanal {
  PRO // Captación online vía /vender
  CN // Captación en oficina por agente
}

enum VehicleType {
  CAMPER
  AUTOCARAVANA
}

/// Taxonomía RV (Fase #3 v1) — carrocería / categoría del vehículo.
enum VehicleCategory {
  MINI_CAMPER
  CAMPER // camper compacta (tipo California)
  GRAN_VOLUMEN // furgón grande camperizado (Ducato L2H2/L3H2…)
  PERFILADA
  CAPUCHINA
  INTEGRAL
}

/// Distribución de la zona de descanso.
enum BedLayout {
  TRANSVERSAL
  LONGITUDINAL
  GEMELAS
  ISLA
  FRANCESA
  BASCULANTE // cama elevable que baja del techo
  LITERAS
  TECHO_ELEVABLE // cama en el pop-top
  DINETTE // salón convertible en cama
}

/// Configuración de baño.
enum BathroomType {
  NINGUNO
  HUMEDO // ducha + WC en el mismo espacio (wet bath)
  SEPARADO // ducha independiente / baño partido
}

/// Carnet necesario para conducir el vehículo (según MMA).
enum LicenseType {
  B // hasta 3.500 kg
  C1 // > 3.500 kg
}

/// Tipo de calefacción de la célula.
enum HeatingType {
  NINGUNA
  GAS
  DIESEL
  ELECTRICA
}

enum ConservationState {
  EXCELENTE
  BUENO
  NORMAL
  DETERIORADO
}

// nuevo → tasado → publicado → reservado → vendido / descartado
enum VehicleStatus {
  NUEVO
  TASADO
  PUBLICADO
  RESERVADO
  VENDIDO
  DESCARTADO
}

// nuevo → contactado → cualificado → en_negociacion → cerrado / descartado
enum SellerLeadStatus {
  NUEVO
  CONTACTADO
  CUALIFICADO
  EN_NEGOCIACION
  CERRADO
  DESCARTADO
}

// nuevo → contactado → cualificado → en_negociacion → cerrado / perdido
enum BuyerLeadStatus {
  NUEVO
  CONTACTADO
  CUALIFICADO
  EN_NEGOCIACION
  CERRADO
  PERDIDO
}

// sugerido → propuesto_cliente → visita → oferta → cerrado / rechazado
enum MatchStatus {
  SUGERIDO
  PROPUESTO_CLIENTE
  VISITA
  OFERTA
  CERRADO
  RECHAZADO
}

/// Ciclo de vida de una oferta comprador→vehículo (Transaction Layer, Block 18).
/// Una oferta ACEPTADA con señal (`depositAmount`) es una reserva.
enum OfferStatus {
  PROPUESTA // oferta presentada al vendedor/CampersNova
  CONTRAOFERTA // en negociación
  ACEPTADA // aceptada; con señal = reserva activa
  CONVERTIDA // cerrada como venta (pasa a entrega)
  RECHAZADA // no aceptada
  EXPIRADA // caducó sin cerrar
  RETIRADA // el comprador la retiró
  CANCELADA // reserva caída tras aceptación
}

enum ActivityType {
  CAMBIO_ESTADO
  NOTA
  LLAMADA
  EMAIL
  WHATSAPP_INICIADO
  MATCH_CREADO
  LEAD_ASIGNADO
  LEAD_CREADO_CHAT
  ANUNCIO_GENERADO
  FOTOS_DESCARGADAS
  COSTE_IMPUTADO
  ORDEN_TALLER_CREADA
  ORDEN_TALLER_COMPLETADA
  ORDEN_TALLER_APROBADA
  ORDEN_TALLER_RECHAZADA
  PRECIO_VENTA_AJUSTADO
  ENTREGA_PROGRAMADA
  ENTREGA_COMPLETADA
  ENTREGA_CANCELADA
  GARANTIA_ACTIVADA
  GARANTIA_AMPLIADA
  TICKET_POSTVENTA_ABIERTO
  TICKET_POSTVENTA_RESUELTO
  TICKET_POSTVENTA_CERRADO
  FOLLOWUP_ENVIADO
  FOLLOWUP_RESPONDIDO
  DOCUMENTO_SUBIDO
  DOCUMENTO_ELIMINADO
  MATRICULA_AÑADIDA
  ITV_ACTUALIZADA
  CARGAS_VERIFICADAS
  TITULARIDAD_TRANSFERIDA
  PUBLICACION_BLOQUEADA
  PROXIMA_ACCION_ACTUALIZADA
  TEMPERATURA_ACTUALIZADA
  OFERTA_REGISTRADA
  OFERTA_ACTUALIZADA
  TRUST_SELLO_OTORGADO
  TRUST_SELLO_REVOCADO
  // Archivado real (PR B1): valores añadidos de forma aditiva para que PR B2 pueda registrar
  // archivado/reactivación sin necesitar otra migración. Aún no se emiten.
  LEAD_ARCHIVADO
  LEAD_REACTIVADO
}

/// Temperatura comercial del lead comprador (CAM-62).
enum LeadTemperature {
  HOT
  WARM
  COLD
}

/// Tipo de vehículo que el comprador entrega como parte de pago (CAM-63).
enum TradeInVehicleType {
  COCHE
  CAMPER
  AUTOCARAVANA
  FURGONETA
  MOTO
  OTRO
}

/// Motivo estructurado de pérdida/descarte de un lead (CAM-61).
enum LostReason {
  PRECIO
  FINANCIACION
  COMPRO_A_OTRO
  NO_RESPONDE
  APLAZA
  SIN_STOCK
  EXPECTATIVAS
  OTRO
}

/// Motivo ORGANIZATIVO del archivado (PR B1). Es ortogonal a `LostReason`, que expresa el motivo
/// COMERCIAL de una pérdida/descarte. `POSIBLE_DUPLICADO` es solo una etiqueta de motivo: este PR
/// no introduce detección ni fusión de duplicados.
enum ArchiveReason {
  SIN_RESPUESTA
  FUERA_DE_MERCADO
  POSIBLE_DUPLICADO
  PRUEBA_INTERNA
  LIMPIEZA_BANDEJA
  OTRO
}

/// Modalidad de acuerdo con el vendedor (Seller Supply Graph, Block 17).
enum SellerDealType {
  DEPOSITO_VENTA // consignación: custodia + venta a comisión (modelo core)
  COMPRA_DIRECTA // CampersNova compra el vehículo
  PARTE_PAGO // entra como parte de pago de otra compra
  INDECISO // el vendedor aún no lo ha decidido
}

/// Urgencia real del vendedor por cerrar (Seller Supply Graph, Block 17).
enum SellerUrgency {
  ALTA
  MEDIA
  BAJA
}

/// Nivel de riesgo mecánico/documental del vehículo del vendedor (Block 17).
enum SellerRisk {
  BAJO
  MEDIO
  ALTO
}

/// Portal de origen de una captación de vehículo (fase 0 del vendedor).
enum CapturePortal {
  COCHES_NET
  WALLAPOP
  MILANUNCIOS
  OTRO
}

/// Estado de una captación de vehículo captado en portales.
enum CaptureStatus {
  NO_CONTACTADO
  CONTACTADO
  EN_CURSO
  ENTRADA_AGENDADA
  CONVERTIDO
  RECHAZADO
}

/// Próxima acción comercial sobre un lead (CAM-60).
enum NextActionType {
  LLAMAR
  WHATSAPP
  EMAIL
  ENVIAR_VEHICULOS
  PEDIR_DOCS
  AGENDAR_VISITA
  SEGUIMIENTO
  CERRAR
}

/// Tipos de evento propios del calendario (F2). Los que ya tienen hogar
/// (entrega→Delivery, reparación/mejora→WorkOrder) NO viven aquí.
enum CalendarEventType {
  CITA
  LLAMADA
  LIMPIEZA
  SEGUIMIENTO
  OTRO
}

enum CalendarEventStatus {
  PROGRAMADO
  CONFIRMADO
  EN_CURSO
  COMPLETADO
  CANCELADO
  NO_SHOW
}

enum CalendarEventPriority {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

enum VehicleDocumentCategory {
  DNI_VENDEDOR
  CONTRATO_COMPRAVENTA
  FICHA_TECNICA
  PERMISO_CIRCULACION
  ITV_VIGENTE
  JUSTIFICANTE_PAGO
  INFORME_CARGAS_DGT
  LIBRO_MANTENIMIENTO
  FACTURA_COMPRA_ORIGINAL
  CONTRATO_FINAL_VENTA
  OTRO
}

enum VehicleCostCategory {
  PIEZAS
  MANO_OBRA_TALLER
  INSTALACION
  LIMPIEZA
  MARKETING
  CUSTODIA
  POSTVENTA
  OTRO
}

enum WorkOrderStatus {
  PENDIENTE
  EN_DIAGNOSTICO
  PRESUPUESTADA
  EN_CURSO
  COMPLETADA
  RECHAZADA
}

/// Naturaleza del trabajo de taller (F4): reparar un problema vs añadir valor.
enum WorkOrderKind {
  REPARACION
  MEJORA
}

enum WorkOrderApprovalLevel {
  NO_REQUIERE
  REQUIERE_CEO
  APROBADA_CEO
  RECHAZADA_CEO
}

enum ChecklistItemCategory {
  MECANICA
  CAMPER
  ELECTRICIDAD
}

enum ChecklistItemResult {
  PENDIENTE
  OK
  NECESITA_REPARACION
  NO_APLICA
}

enum AdChannel {
  WALLAPOP
  COCHESNET
}

enum BuyerChatStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
  REDIRECTED_SELLER
}

enum ValuationMethod {
  AUTO
  MANUAL
}

enum ValuationConfidence {
  ALTA
  MEDIA
  BAJA
}

enum DocumentType {
  DNI
  FICHA_TECNICA
  ITV
  CONTRATO
  OTROS
}

enum DeliveryStatus {
  PROGRAMADA
  EN_CURSO
  COMPLETADA
  CANCELADA
